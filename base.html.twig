<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Cars Lists{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    {% block extra_css %}{% endblock %}
    <style>
        :root {
            --sidebar-bg: #1a1d23;
            --sidebar-width: 240px;
            --accent: #4f8ef7;
            --accent-hover: #3a7ae4;
        }

        body {
            background: #f4f6fb;
            font-family: 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 100;
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 1.5rem 1.25rem 1rem;
            color: #fff;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.4px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .sidebar-brand i {
            color: var(--accent);
            font-size: 1.4rem;
        }

        .sidebar-nav {
            padding: 1rem 0;
            flex: 1;
        }

        .sidebar-nav .nav-link {
            color: rgba(255, 255, 255, 0.65);
            padding: 0.65rem 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            font-size: 0.9rem;
            border-radius: 0;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            color: #fff;
            background: rgba(79, 142, 247, 0.18);
        }

        .sidebar-nav .nav-link.active {
            border-left: 3px solid var(--accent);
        }

        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .topbar {
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .topbar-title {
            font-weight: 700;
            font-size: 1.15rem;
            color: #1a1d23;
        }

        .card {
            border: none;
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.07);
        }

        .card-header {
            background: #fff;
            border-bottom: 1px solid #f0f0f0;
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.25s;
            }

            .sidebar.show {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand">
        <i class="bi bi-car-front-fill"></i>
        Cars&nbsp;Lists
    </div>

    <nav class="sidebar-nav">
        <a href="index.php" class="nav-link {% if page == 'dashboard' %}active{% endif %}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a href="create.php" class="nav-link {% if page == 'create' %}active{% endif %}">
            <i class="bi bi-plus-circle"></i> Add Car
        </a>
    </nav>

    <div class="px-3 pb-3 mt-auto">
        <a href="logout.php" class="btn btn-sm btn-outline-light w-100">
            <i class="bi bi-box-arrow-right me-2"></i>Logout
        </a>
        <small class="text-secondary d-block mt-2" style="font-size:.75rem;">Cars CRUD &copy; {{ "now"|date("Y") }}</small>
    </div>
</aside>

<div class="main-content">
    {% block content %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block extra_js %}{% endblock %}
</body>
</html>