{% extends "base.html.twig" %}

{% block extra_css %}
<style>
    .card {
        border: none;
        box-shadow: 0 1px 6px rgba(0, 0, 0, 0.07);
    }
</style>
{% endblock %}

{% block content %}
<div class="topbar">
    <button class="btn btn-sm btn-light d-md-none" id="sidebarToggle">
        <i class="bi bi-list fs-5"></i>
    </button>
    <nav aria-label="breadcrumb" class="mb-0">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="index.php">Dashboard</a></li>
            <li class="breadcrumb-item active">{{ page_title }}</li>
        </ol>
    </nav>
</div>

<div class="p-4" style="max-width:680px;">
    <h5 class="fw-bold mb-4">
        <i class="bi {% if is_edit %}bi-pencil-square{% else %}bi-plus-circle{% endif %} me-2 text-primary"></i>
        {% if is_edit %}Edit — {{ car.year }} {{ car.make }} {{ car.model }}{% else %}Add New Car{% endif %}
    </h5>

    {% if errors.csrf %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>{{ errors.csrf }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}

    <div class="card rounded-3">
        <div class="card-body p-4">
            <form method="post" novalidate>
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                {% if is_edit %}<input type="hidden" name="id" value="{{ car.id }}">{% endif %}

                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label fw-semibold">Make <span class="text-danger">*</span></label>
                        <input type="text" name="make" class="form-control {% if errors.make %}is-invalid{% endif %}"
                               value="{{ car.make }}" placeholder="e.g. Toyota">
                        {% if errors.make %}<div class="invalid-feedback">{{ errors.make }}</div>{% endif %}
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label fw-semibold">Model <span class="text-danger">*</span></label>
                        <input type="text" name="model" class="form-control {% if errors.model %}is-invalid{% endif %}"
                               value="{{ car.model }}" placeholder="e.g. Corolla">
                        {% if errors.model %}<div class="invalid-feedback">{{ errors.model }}</div>{% endif %}
                    </div>

                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Year <span class="text-danger">*</span></label>
                        <input type="number" name="year" class="form-control {% if errors.year %}is-invalid{% endif %}"
                               value="{{ car.year }}"
                               min="1886" max="{{ "now"|date("Y") + 1 }}">
                        {% if errors.year %}<div class="invalid-feedback">{{ errors.year }}</div>{% endif %}
                    </div>

                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Color <span class="text-danger">*</span></label>
                        <input type="text" name="color" class="form-control {% if errors.color %}is-invalid{% endif %}"
                               value="{{ car.color }}" placeholder="e.g. White">
                        {% if errors.color %}<div class="invalid-feedback">{{ errors.color }}</div>{% endif %}
                    </div>

                    <div class="col-sm-4">
                        <label class="form-label fw-semibold">Mileage (km)</label>
                        <input type="number" name="mileage" class="form-control {% if errors.mileage %}is-invalid{% endif %}"
                               value="{{ car.mileage }}" min="0" placeholder="0">
                        {% if errors.mileage %}<div class="invalid-feedback">{{ errors.mileage }}</div>{% endif %}
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Price (USD) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" name="price" step="0.01"
                                   class="form-control {% if errors.price %}is-invalid{% endif %}"
                                   value="{{ car.price }}" min="0" placeholder="0.00">
                            {% if errors.price %}<div class="invalid-feedback">{{ errors.price }}</div>{% endif %}
                        </div>
                    </div>
                </div>

                <hr class="my-4">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi {% if is_edit %}bi-check-lg{% else %}bi-check-lg{% endif %} me-1"></i>
                        {% if is_edit %}Update Car{% else %}Save Car{% endif %}
                    </button>
                    <a href="index.php" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('sidebarToggle')?.addEventListener('click', function () {
        document.querySelector('.sidebar').classList.toggle('show');
    });
</script>
{% endblock %}